# =============================================================
# .env.example — Plantilla de variables de entorno
# -------------------------------------------------------------
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Completa cada valor con tus credenciales reales
#   3. NUNCA subas el archivo .env a git
#   4. Este archivo (.env.example) SÍ puede subirse a git
# =============================================================

# ===== BASE DE DATOS =====
DB_URL=jdbc:postgresql://localhost:5433/nombre_base_datos
DB_USERNAME=tu_usuario_postgres
DB_PASSWORD=tu_contraseña_postgres

# ===== STORAGE =====
# Windows ejemplo: C:/gestor-documentos/storage
# Linux ejemplo:   /opt/gestor-documentos/storage
STORAGE_LOCATION=/ruta/al/storage

# ===== JWT =====
# Genera una clave segura con PowerShell:
# [Convert]::ToBase64String((1..64 | ForEach-Object { [byte](Get-Random -Max 256) }))
# O con Git Bash / Linux:
# openssl rand -base64 64
JWT_SECRET=genera_una_clave_segura_aqui
JWT_EXPIRATION_MS=3600000

# ===== EMAIL (Gmail) =====
# MAIL_PASSWORD debe ser una "Contraseña de aplicación" de Google,
# NO tu contraseña personal de Gmail.
# Generala en: myaccount.google.com -> Seguridad -> Contraseñas de aplicaciones
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password_de_16_caracteres
MAIL_FROM=tu_email@gmail.com

# ===== CORS =====
# En produccion cambia esto por la URL real de tu frontend
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ===== SWAGGER =====
# Coloca true solo en desarrollo, nunca en produccion
SWAGGER_ENABLED=true
